        HarvestThreadId = HarvestThreadId + 1

        local MyThreadId = HarvestThreadId

        if not state then
            return
        end

        task.spawn(function()
            while AutoHarvest and MyThreadId == HarvestThreadId do
                local Plot = GetMyPlot()

                if Plot and Plot:FindFirstChild("Plants") then
                    for _, Plant in ipairs(Plot.Plants:GetChildren()) do
                        if not AutoHarvest or MyThreadId ~= HarvestThreadId then
                            return
                        end

                        if PlantMatchesFilter(Plant) and not IsBlacklistedPlant(Plant) then

                            local Fruits = Plant:FindFirstChild("Fruits")

                            if Fruits then
                                for _, Fruit in ipairs(Fruits:GetChildren()) do
                                    if not AutoHarvest or MyThreadId ~= HarvestThreadId then
                                        return
                                    end

                                    if HasSelectedMutation(Fruit) then
                                        local HarvestPart = Fruit:FindFirstChild("HarvestPart")
                                        local HarvestPrompt = HarvestPart and HarvestPart:FindFirstChild("HarvestPrompt")

                                        if HarvestPrompt and HarvestPrompt.Parent then
                                            fireproximityprompt(HarvestPrompt)
                                            task.wait(HarvestDelay)
                                        end
                                    end
                                end
                            else
                                if HasSelectedMutation(Plant) then
                                    local HarvestPart = Plant:FindFirstChild("HarvestPart")
                                    local HarvestPrompt = HarvestPart and HarvestPart:FindFirstChild("HarvestPrompt")

                                    if HarvestPrompt and HarvestPrompt.Parent then
                                        fireproximityprompt(HarvestPrompt)
