local function x(l, y, z)
    local B = ""
    if #l <= 1 then
        return string.format(
            '<font color="#%02X%02X%02X">%s</font>',
            math.floor(y.R * 255 + 0.5),
            math.floor(y.G * 255 + 0.5),
            math.floor(y.B * 255 + 0.5),
            l
        )
    end
    for C = 1, #l do
        local D = (C - 1) / (#l - 1)
        local E = y.R + (z.R - y.R) * D
        local F = y.G + (z.G - y.G) * D
        local p = y.B + (z.B - y.B) * D
        local G =
            string.format(
            "#%02X%02X%02X",
            math.floor(E * 255 + 0.5),
            math.floor(F * 255 + 0.5),
            math.floor(p * 255 + 0.5)
        )
        B = B .. string.format('<font color="%s">%s</font>', G, l:sub(C, C))
    end
    return B
end

