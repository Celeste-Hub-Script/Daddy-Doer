-- Send Webhook Function
local function SendWebhook(Title, Description, SettingName)
    if not WebhooksEnabled then
        return
    end

    if not request then
        warn("No HTTP request function found.")
        return
    end

    if not WebhookSettings[SettingName] then
        return
    end

    if WebhookURL == "" then
        return
    end

    local Success, Response = pcall(function()
        return request({
            Url = WebhookURL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode({
                embeds = {{
                    title = Title,
                    description = Description,
                    color = 15548997, -- Discord Red
                    footer = {
                        text = LocalPlayer.Name
                    }
                }}
            })
        })
    end)

    if Success and Response then
        print("Webhook Status:", Response.StatusCode)
    else
        warn("Webhook Error:", Response)
    end
end

