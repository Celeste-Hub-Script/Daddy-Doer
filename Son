local MutationMap = {
    Frozen     = "FrozenVFX",
    Gold       = "GoldVFX",
    Rainbow    = "RainbowVFX",
    Electric   = "ElectricVFX",
    Chained    = "ChainedVFX",
    Bloodlit   = "BloodlitVFX",
    Pizza      = "PizzaVFX",
    Starstruck = "StarstruckVFX",
    Secret     = "SecretVFX",
}

local function HasSelectedMutation(Fruit)
    if not next(SelectedMutations) then
        return true
    end

    local HasAnyMutation = false

    for _, Child in ipairs(Fruit:GetChildren()) do
        if Child.Name:find("VFX") then
            HasAnyMutation = true
            break
        end
    end

    for _, Selected in ipairs(SelectedMutations) do
        if Selected == "All" then
            return true
        end

        if Selected == "None" and not HasAnyMutation then
            return true
        end

        local VFXName = MutationMap[Selected]

        if VFXName and Fruit:FindFirstChild(VFXName) then
            return true
        end
    end

    return false
end

local function PlantMatchesFilter(Plant)
    if not next(SelectedPlants) then
        return true
    end

    for _, Selected in ipairs(SelectedPlants) do
        if Selected == "All" then
            return true
        end
    end

    local SeedName = Plant:GetAttribute("SeedName")

    for _, Selected in ipairs(SelectedPlants) do
        if Selected == SeedName then
            return true
        end
    end

    return false
end

local function IsBlacklistedPlant(Plant)
    local SeedName = Plant:GetAttribute("SeedName")

    for _, Blacklisted in ipairs(BlacklistedPlants) do
        if Blacklisted == SeedName then
            return true
        end
    end

    return false
end

