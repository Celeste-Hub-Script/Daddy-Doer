    local SeedName = Plant:GetAttribute("SeedName")

    for _, Selected in ipairs(StealSelectedPlants) do
        if Selected == SeedName then
            return true
        end
    end

    return false
end

local function StealIsBlacklistedPlant(Plant)
    local SeedName = Plant:GetAttribute("SeedName")

    for _, Blacklisted in ipairs(StealBlacklistedPlants) do
