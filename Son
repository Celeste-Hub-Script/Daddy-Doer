--// Discord Invite Data
local InviteCode = "H4xScripts"
local InviteAPI =
    ("https://discord.com/api/v10/invites/%s?with_counts=true&with_expiration=true"):format(InviteCode)

local HttpService = game:GetService("HttpService")
local DiscordData
local FetchError = nil

local function fetchDiscordData()
    local body
    local ok, res =
        pcall(
        function()
            if t.Creator and type(t.Creator.Request) == "function" then
                return t.Creator.Request(
                    {
                        Url = InviteAPI,
                        Method = "GET",
                        Headers = {
                            ["Accept"] = "application/json"
                        }
                    }
                )
            end
        end
    )
    if ok and res then
        body = res.Body or res.body or res
    end
    body = body or e(InviteAPI)
    if type(body) ~= "string" or #body == 0 then
        return nil, "empty discord response"
    end
    local decoded, data =
        pcall(
        function()
            return HttpService:JSONDecode(body)
        end
    )
    if not decoded then
        return nil, data
    end
    return data
end

--// Fetch Discord Info
xpcall(function()
    local data, err = fetchDiscordData()
    if not data then
