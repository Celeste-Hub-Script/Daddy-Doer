for _, Item in ipairs(Backpack:GetChildren()) do
    if Item:GetAttribute("MainCategory") == "Seed" then
        local SeedName = Item:GetAttribute("SeedTool") or Item.Name
        PreviousCounts[SeedName] = Item:GetAttribute("Count") or 0
    end
end

task.spawn(function()
    while task.wait(0.1) do
        for _, Item in ipairs(Backpack:GetChildren()) do

            local Count = Item:GetAttribute("Count")
            local SeedName = Item:GetAttribute("SeedTool") or Item.Name
            local OldCount = PreviousCounts[SeedName] or 0

            if Item:GetAttribute("MainCategory") == "Seed" and Count then
                if Count > OldCount then
                    local BoughtAmount = Count - OldCount

                    SendWebhook(
                        "🌱 Seed Purchased",
                        string.format(
                            "**Seed:** %s\n**Bought:** %s\n**Total:** %s",
                            SeedName,
                            BoughtAmount,
                            Count
                        ),
                        "FruitBought"
                    )
                end
            end

            PreviousCounts[SeedName] = Count or 0
        end
    end
end)

local HarvestQueue = {}
local SeenFruitIds = {}

Backpack.DescendantAdded:Connect(function(Item)
    local FruitId = Item:GetAttribute("Id")
    local FruitName = Item:GetAttribute("Fruit")

    if not FruitId or not FruitName then
        return
    end

    if SeenFruitIds[FruitId] then
        return
    end

    SeenFruitIds[FruitId] = true
    HarvestQueue[FruitName] = (HarvestQueue[FruitName] or 0) + 1
end)

task.spawn(function()
    while task.wait(5) do
        if next(HarvestQueue) then
            local Lines = {}

            for FruitName, Amount in pairs(HarvestQueue) do
                table.insert(Lines, string.format("%s x%s", FruitName, Amount))
            end

            table.sort(Lines)

            SendWebhook(
                "🍎 Fruits Harvested",
                table.concat(Lines, "\n"),
                "FruitHarvested"
            )

            table.clear(HarvestQueue)
        end
    end
end)

local PreviousGearCounts = {}

